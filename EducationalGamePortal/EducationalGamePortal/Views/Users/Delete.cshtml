@model EducationalGamePortal.Models.User

@{
    ViewData["Title"] = "Видалити гравця";
}

<h1>Видалити гравця</h1>

<div class="alert alert-danger">
    <h4>Ви впевнені, що хочете видалити цього гравця?</h4>
    <p>Цю дію не можна скасувати. Разом з гравцем будуть видалені всі його ігрові сесії та досягнення.</p>
</div>

<div class="card" style="max-width: 400px;">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-4">ID</dt>
            <dd class="col-sm-8">@Model.Id</dd>
            <dt class="col-sm-4">Нікнейм</dt>
            <dd class="col-sm-8">@Model.Nickname</dd>
            <dt class="col-sm-4">Email</dt>
            <dd class="col-sm-8">@Model.Email</dd>
        </dl>
    </div>
</div>

<form asp-action="Delete" method="post" class="mt-3">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Так, видалити</button>
    <a asp-action="Index" class="btn btn-secondary">Скасувати</a>
</form>

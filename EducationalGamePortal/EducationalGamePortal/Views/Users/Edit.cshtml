@model EducationalGamePortal.Models.User

@{
    ViewData["Title"] = "Редагувати гравця";
}

<h1>Редагувати гравця</h1>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit">
            <div asp-validation-summary="All" class="text-danger"></div>

            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="PasswordHash" />
            <input type="hidden" asp-for="RegistrationDate" />

            <div class="mb-3">
                <label asp-for="Nickname" class="form-label">Нікнейм</label>
                <input asp-for="Nickname" class="form-control" />
            </div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label">Email</label>
                <input asp-for="Email" class="form-control" type="email" />
            </div>

            <div class="mb-3">
                <button type="submit" class="btn btn-warning">Зберегти зміни</button>
                <a asp-action="Index" class="btn btn-secondary">Скасувати</a>
            </div>
        </form>
    </div>
</div>

@model EducationalGamePortal.Models.User

@{
    ViewData["Title"] = "Профіль гравця";
}

<h1>@Model.Nickname</h1>

<div class="row">
    <div class="col-md-6">
        <div class="card mb-3">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">Інформація про гравця</h5>
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">ID</dt>
                    <dd class="col-sm-8">@Model.Id</dd>
                    <dt class="col-sm-4">Нікнейм</dt>
                    <dd class="col-sm-8">@Model.Nickname</dd>
                    <dt class="col-sm-4">Email</dt>
                    <dd class="col-sm-8">@Model.Email</dd>
                    <dt class="col-sm-4">Реєстрація</dt>
                    <dd class="col-sm-8">@Model.RegistrationDate.ToString("dd.MM.yyyy HH:mm")</dd>
                    <dt class="col-sm-4">Загальний XP</dt>
                    <dd class="col-sm-8">@Model.GameSessions.Sum(s => s.Score)</dd>
                </dl>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card mb-3">
            <div class="card-header bg-success text-white">
                <h5 class="mb-0">Досягнення (@Model.UserAchievements.Count)</h5>
            </div>
            <div class="card-body">
                @if (Model.UserAchievements.Any())
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var ua in Model.UserAchievements)
                        {
                            <li class="list-group-item">
                                <strong>@ua.Achievement.Title</strong>
                                <br />
                                <small class="text-muted">@ua.Achievement.Description — отримано @ua.UnlockedAt.ToString("dd.MM.yyyy")</small>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <p class="text-muted">Поки що немає досягнень.</p>
                }
            </div>
        </div>
    </div>
</div>

<h3>Історія ігрових сесій</h3>

@if (Model.GameSessions.Any())
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Гра</th>
                <th>Рівень</th>
                <th>Складність</th>
                <th>Бали</th>
                <th>Час</th>
                <th>Статус</th>
                <th>Дата</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var session in Model.GameSessions.OrderByDescending(s => s.PlayedAt))
            {
                <tr>
                    <td>@session.Level.Game.Title</td>
                    <td>@session.Level.Title</td>
                    <td>
                        @if (session.Level.Difficulty == "Easy")
                        {
                            <span>Легкий</span>
                        }
                        else if (session.Level.Difficulty == "Medium")
                        {
                            <span>Середній</span>
                        }
                        else
                        {
                            <span>Складний</span>
                        }
                    </td>
                    <td>@session.Score / @session.Level.MaxScore</td>
                    <td>@TimeSpan.FromSeconds(session.TimeSpent).ToString(session.TimeSpent >= 3600 ? @"h\:mm\:ss" : @"mm\:ss")</td>
                    <td>
                        @if (session.IsCompleted)
                        {
                            <span class="badge bg-success">Пройдено</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Не пройдено</span>
                        }
                    </td>
                    <td>@session.PlayedAt.ToString("dd.MM.yyyy HH:mm")</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p class="text-muted">Гравець ще не грав у жодну гру.</p>
}

<a asp-action="Index" class="btn btn-secondary mt-3">Назад до списку</a>

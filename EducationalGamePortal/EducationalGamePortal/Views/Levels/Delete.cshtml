@model EducationalGamePortal.Models.Level

@{
    ViewData["Title"] = "Видалити рівень";
}

<h1>Видалити рівень</h1>

<div class="alert alert-danger">
    <h4>Ви впевнені, що хочете видалити цей рівень?</h4>
    <p>Цю дію не можна скасувати. Разом з рівнем будуть видалені всі пов'язані ігрові сесії.</p>
</div>

<div class="card" style="max-width: 400px;">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-4">ID</dt>
            <dd class="col-sm-8">@Model.Id</dd>
            <dt class="col-sm-4">Гра</dt>
            <dd class="col-sm-8">@Model.Game.Title</dd>
            <dt class="col-sm-4">Назва</dt>
            <dd class="col-sm-8">@Model.Title</dd>
            <dt class="col-sm-4">Складність</dt>
            <dd class="col-sm-8">@Model.Difficulty</dd>
        </dl>
    </div>
</div>

<form asp-action="Delete" method="post" class="mt-3">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Так, видалити</button>
    <a asp-controller="Games" asp-action="Details" asp-route-id="@Model.GameId" class="btn btn-secondary">Скасувати</a>
</form>

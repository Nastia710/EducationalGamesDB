@model EducationalGamePortal.Models.Level

@{
    ViewData["Title"] = Model.Title;
}

<h1>@Model.Title</h1>

<div class="row">
    <div class="col-md-6">
        <div class="card mb-3">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">Інформація про рівень</h5>
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">ID</dt>
                    <dd class="col-sm-8">@Model.Id</dd>
                    <dt class="col-sm-4">Гра</dt>
                    <dd class="col-sm-8">
                        <a asp-controller="Games" asp-action="Details" asp-route-id="@Model.GameId">@Model.Game.Title</a>
                    </dd>
                    <dt class="col-sm-4">№ рівня</dt>
                    <dd class="col-sm-8">@Model.LevelNumber</dd>
                    <dt class="col-sm-4">Складність</dt>
                    <dd class="col-sm-8">
                        @if (Model.Difficulty == "Easy")
                        {
                            <span>Легкий</span>
                        }
                        else if (Model.Difficulty == "Medium")
                        {
                            <span>Середній</span>
                        }
                        else
                        {
                            <span>Складний</span>
                        }
                    </dd>
                    <dt class="col-sm-4">Макс. бали</dt>
                    <dd class="col-sm-8">@Model.MaxScore</dd>
                    <dt class="col-sm-4">Кількість сесій</dt>
                    <dd class="col-sm-8">@Model.GameSessions.Count</dd>
                </dl>
            </div>
        </div>
    </div>
</div>

<h3>Ігрові сесії на цьому рівні</h3>

@if (Model.GameSessions.Any())
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Гравець</th>
                <th>Бали</th>
                <th>Час</th>
                <th>Статус</th>
                <th>Дата</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var session in Model.GameSessions.OrderByDescending(s => s.PlayedAt))
            {
                <tr>
                    <td>
                        <a asp-controller="Users" asp-action="Details" asp-route-id="@session.UserId">@session.User.Nickname</a>
                    </td>
                    <td>@session.Score / @Model.MaxScore</td>
                    <td>@TimeSpan.FromSeconds(session.TimeSpent).ToString(session.TimeSpent >= 3600 ? @"h\:mm\:ss" : @"mm\:ss")</td>
                    <td>
                        @if (session.IsCompleted)
                        {
                            <span class="badge bg-success">Пройдено</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Не пройдено</span>
                        }
                    </td>
                    <td>@session.PlayedAt.ToString("dd.MM.yyyy HH:mm")</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p class="text-muted">Ніхто ще не грав на цьому рівні.</p>
}

<button onclick="history.back()" class="btn btn-secondary mt-3">Назад</button>

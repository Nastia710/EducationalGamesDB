@model IEnumerable<EducationalGamePortal.Models.Level>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Гра</th>
            <th>№ рівня</th>
            <th>Назва</th>
            <th>Складність</th>
            <th>Макс. бали</th>
            <th>Дії</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var level in Model)
        {
            <tr>
                <td>@level.Id</td>
                <td>@level.Game.Title</td>
                <td>@level.LevelNumber</td>
                <td>@level.Title</td>
                <td>
                    @if (level.Difficulty == "Easy")
                    {
                        <span>Легкий</span>
                    }
                    else if (level.Difficulty == "Medium")
                    {
                        <span>Середній</span>
                    }
                    else
                    {
                        <span>Складний</span>
                    }
                </td>
                <td>@level.MaxScore</td>
                <td>
                    <a asp-action="Details" asp-route-id="@level.Id" class="btn btn-sm btn-info">Деталі</a>
                    <a asp-action="Edit" asp-route-id="@level.Id" class="btn btn-sm btn-warning">Редагувати</a>
                    <a asp-action="Delete" asp-route-id="@level.Id" class="btn btn-sm btn-danger">Видалити</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@model EducationalGamePortal.Models.Game

@{
    ViewData["Title"] = "Додати гру";
}

<h1>Додати нову гру</h1>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="All" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="Title" class="form-label">Назва</label>
                <input asp-for="Title" class="form-control" placeholder="Введіть назву гри" />
            </div>

            <div class="mb-3">
                <label asp-for="Subject" class="form-label">Предмет</label>
                <input asp-for="Subject" class="form-control" placeholder="Наприклад: Математика" />
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label">Опис</label>
                <textarea asp-for="Description" class="form-control" rows="3" placeholder="Короткий опис гри"></textarea>
            </div>

            <div class="mb-3">
                <button type="submit" class="btn btn-primary">Створити</button>
                <a asp-action="Index" class="btn btn-secondary">Скасувати</a>
            </div>
        </form>
    </div>
</div>

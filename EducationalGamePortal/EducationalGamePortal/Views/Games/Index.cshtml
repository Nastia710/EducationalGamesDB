@model IEnumerable<EducationalGamePortal.Models.Game>

@{
    ViewData["Title"] = "Ігри";
}

<h1>Ігри</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Додати нову гру</a>
</p>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Назва</th>
            <th>Предмет</th>
            <th>Опис</th>
            <th>Кількість рівнів</th>
            <th>Дії</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var game in Model)
        {
            <tr>
                <td>@game.Id</td>
                <td>@game.Title</td>
                <td>@game.Subject</td>
                <td>@(game.Description ?? "—")</td>
                <td>@game.Levels.Count</td>
                <td>
                    <a asp-action="Details" asp-route-id="@game.Id" class="btn btn-sm btn-info">Деталі</a>
                    <a asp-action="Edit" asp-route-id="@game.Id" class="btn btn-sm btn-warning">Редагувати</a>
                    <a asp-action="Delete" asp-route-id="@game.Id" class="btn btn-sm btn-danger">Видалити</a>
                </td>
            </tr>
        }
    </tbody>
</table>

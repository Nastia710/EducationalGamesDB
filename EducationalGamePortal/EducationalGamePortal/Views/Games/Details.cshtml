@model EducationalGamePortal.Models.Game

@{
    ViewData["Title"] = Model.Title;
}

<h1>@Model.Title</h1>

<div class="row">
    <div class="col-md-6">
        <div class="card mb-3">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">Інформація про гру</h5>
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">ID</dt>
                    <dd class="col-sm-8">@Model.Id</dd>
                    <dt class="col-sm-4">Назва</dt>
                    <dd class="col-sm-8">@Model.Title</dd>
                    <dt class="col-sm-4">Предмет</dt>
                    <dd class="col-sm-8">@Model.Subject</dd>
                    <dt class="col-sm-4">Опис</dt>
                    <dd class="col-sm-8">@(Model.Description ?? "—")</dd>
                    <dt class="col-sm-4">Кількість рівнів</dt>
                    <dd class="col-sm-8">@Model.Levels.Count</dd>
                </dl>
            </div>
        </div>
    </div>
</div>

<div class="d-flex justify-content-between align-items-center mb-2">
    <h3 class="mb-0">Рівні</h3>
    <a asp-controller="Levels" asp-action="Create" asp-route-gameId="@Model.Id" class="btn btn-sm btn-primary">Додати рівень</a>
</div>

@if (Model.Levels.Any())
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>№</th>
                <th>Назва</th>
                <th>Складність</th>
                <th>Макс. бали</th>
                <th>Кількість сесій</th>
                <th>Дії</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var level in Model.Levels.OrderBy(l => l.LevelNumber))
            {
                <tr>
                    <td>@level.LevelNumber</td>
                    <td>@level.Title</td>
                    <td>
                        @if (level.Difficulty == "Easy")
                        {
                            <span>Легкий</span>
                        }
                        else if (level.Difficulty == "Medium")
                        {
                            <span>Середній</span>
                        }
                        else
                        {
                            <span>Складний</span>
                        }
                    </td>
                    <td>@level.MaxScore</td>
                    <td>@level.GameSessions.Count</td>
                    <td>
                        <a asp-controller="Levels" asp-action="Details" asp-route-id="@level.Id" class="btn btn-sm btn-info">Деталі</a>
                        <a asp-controller="Levels" asp-action="Edit" asp-route-id="@level.Id" class="btn btn-sm btn-warning">Редагувати</a>
                        <a asp-controller="Levels" asp-action="Delete" asp-route-id="@level.Id" class="btn btn-sm btn-danger">Видалити</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p class="text-muted">У цій грі ще немає рівнів.</p>
}

<a asp-action="Index" class="btn btn-secondary mt-3">Назад до списку</a>

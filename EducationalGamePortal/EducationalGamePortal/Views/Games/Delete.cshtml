@model EducationalGamePortal.Models.Game

@{
    ViewData["Title"] = "Видалити гру";
}

<h1>Видалити гру</h1>

<div class="alert alert-danger">
    <h4>Ви впевнені, що хочете видалити цю гру?</h4>
    <p>Цю дію не можна скасувати. Разом з грою будуть видалені всі її рівні та пов'язані ігрові сесії.</p>
</div>

<div class="card" style="max-width: 400px;">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-4">ID</dt>
            <dd class="col-sm-8">@Model.Id</dd>
            <dt class="col-sm-4">Назва</dt>
            <dd class="col-sm-8">@Model.Title</dd>
            <dt class="col-sm-4">Предмет</dt>
            <dd class="col-sm-8">@Model.Subject</dd>
        </dl>
    </div>
</div>

<form asp-action="Delete" method="post" class="mt-3">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Так, видалити</button>
    <a asp-action="Index" class="btn btn-secondary">Скасувати</a>
</form>
